# Copy this file to .env and fill in the values.
# .env is gitignored and never committed.

# Required: password all users enter to sign in
APP_PASSWORD=changeme

# Required for Create Rules / Policy Analyst (Claude integration)
ANTHROPIC_API_KEY=sk-ant-...

# Optional: set a fixed session secret so sessions survive server restarts.
# If not set, a random secret is generated each startup (logs everyone out on restart).
SESSION_SECRET=
